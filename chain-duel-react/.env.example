# Socket URL for the game backend (marspay). No /loadconfig API on marspay – set one of these.
# If you set a ws/wss URL here, the app uses it as the socket URL and does not call /loadconfig.
VITE_SOCKET_URL=wss://marspay.chainduel.net

# Alternative: VITE_PROXY_TARGET=wss://... is also treated as the socket URL (no /loadconfig call).
# For HTTP proxy only (legacy chain-duel server): VITE_PROXY_TARGET=http://localhost:3000
